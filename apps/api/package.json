{
  "name": "@nitbox/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src}/**/*.ts\"",
    "clean": "rm -rf dist",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed/index.ts",
    "seed:static": "ts-node -r tsconfig-paths/register prisma/seed/index.ts static",
    "seed:teams": "ts-node -r tsconfig-paths/register prisma/seed/index.ts teams",
    "seed:competitions": "ts-node -r tsconfig-paths/register prisma/seed/index.ts competitions",
    "seed:players": "ts-node -r tsconfig-paths/register prisma/seed/index.ts players",
    "seed:fixtures": "ts-node -r tsconfig-paths/register prisma/seed/index.ts fixtures",
    "seed:standings": "ts-node -r tsconfig-paths/register prisma/seed/index.ts standings",
    "seed:player-season-stats": "ts-node -r tsconfig-paths/register prisma/seed/index.ts player-season-stats",
    "seed:coaches": "ts-node -r tsconfig-paths/register prisma/seed/index.ts coaches"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nitbox/types": "*",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
