generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// CONFEDERATIONS
// ---------------------------------------------------------------------------

model Confederation {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(10)   // "UEFA", "CONMEBOL", "CAF", "AFC", "CONCACAF", "OFC", "FIFA"
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  countries    Country[]
  competitions Competition[]

  @@map("confederations")
}

// ---------------------------------------------------------------------------
// COUNTRIES
// ---------------------------------------------------------------------------

model Country {
  id              Int           @id @default(autoincrement())
  isoAlpha2       String        @db.VarChar(2)
  isoAlpha3       String        @unique @db.VarChar(3)
  name            String        @unique @db.VarChar(100)
  flagUrl         String?       @db.VarChar(500)
  confederationId Int
  confederation   Confederation @relation(fields: [confederationId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  nationalTeam      NationalTeam?
  venues            Venue[]
  players           Player[]
  playersBornHere   Player[]      @relation("BirthCountry")
  coachesBornHere   Coach[]       @relation("CoachBirthCountry")
  coachNationality  Coach[]       @relation("CoachNationality")
  hostedSeasons     CompetitionSeason[]

  @@map("countries")
}

// ---------------------------------------------------------------------------
// VENUES
// ---------------------------------------------------------------------------

model Venue {
  id            Int      @id @default(autoincrement())
  apiFootballId Int?     @unique
  name          String   @db.VarChar(200)
  address       String?  @db.VarChar(255)
  city          String   @db.VarChar(100)
  countryId     Int
  country       Country  @relation(fields: [countryId], references: [id])
  capacity      Int?
  surfaceType   String?  @db.VarChar(50)
  imageUrl      String?  @db.VarChar(500)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  matches Match[]

  @@unique([name, countryId])
  @@map("venues")
}

// ---------------------------------------------------------------------------
// NATIONAL TEAMS
// ---------------------------------------------------------------------------

model NationalTeam {
  id            Int      @id @default(autoincrement())
  apiFootballId Int      @unique
  countryId     Int      @unique
  country       Country  @relation(fields: [countryId], references: [id])
  fifaCode      String?  @unique @db.VarChar(3)   // nullable — not all teams have a FIFA code
  name          String   @db.VarChar(100)
  logoUrl       String?  @db.VarChar(500)
  founded       Int?
  national      Boolean  @default(true)
  fifaRanking   Int?                               // manual enrichment
  nickname      String?  @db.VarChar(100)
  kitPrimary    String?  @db.VarChar(20)
  kitSecondary  String?  @db.VarChar(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  homeMatches       Match[]               @relation("HomeTeam")
  awayMatches       Match[]               @relation("AwayTeam")
  squads            Squad[]
  coachAssignments  CoachAssignment[]
  standings         Standing[]
  teamSeasonStats   TeamSeasonStats[]
  matchTeamStats    MatchTeamStatistics[]
  matchEvents       MatchEvent[]
  matchLineups      MatchLineup[]
  playerMatchStats  PlayerMatchStats[]
  playerSeasonStats PlayerSeasonStats[]
  trophies          Trophy[]

  @@map("national_teams")
}

// ---------------------------------------------------------------------------
// COMPETITIONS
// ---------------------------------------------------------------------------

model Competition {
  id            Int            @id @default(autoincrement())
  apiFootballId Int            @unique
  name          String         @db.VarChar(200)   // no @unique — "Friendlies" appears per confederation
  shortName     String?        @db.VarChar(50)
  type          String         @db.VarChar(50)    // "world_cup", "continental", "qualifier", "friendly"
  confederationId Int?
  confederation  Confederation? @relation(fields: [confederationId], references: [id])
  logoUrl       String?        @db.VarChar(500)
  flagUrl       String?        @db.VarChar(500)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  seasons CompetitionSeason[]

  @@index([name])
  @@map("competitions")
}

// ---------------------------------------------------------------------------
// COMPETITION SEASONS
// ---------------------------------------------------------------------------

model CompetitionSeason {
  id                Int         @id @default(autoincrement())
  competitionId     Int
  competition       Competition @relation(fields: [competitionId], references: [id])
  apiFootballSeason Int                             // NOT NULL — required for all API calls
  label             String      @db.VarChar(20)
  startDate         DateTime    @db.Date
  endDate           DateTime    @db.Date
  isCurrent         Boolean     @default(false)
  hostCountryId     Int?
  hostCountry       Country?    @relation(fields: [hostCountryId], references: [id])
  coverageFlags     Json?                           // seasons[].coverage from GET /leagues
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  groups            CompetitionGroup[]
  matches           Match[]
  standings         Standing[]
  teamSeasonStats   TeamSeasonStats[]
  playerSeasonStats PlayerSeasonStats[]
  trophies          Trophy[]
  squads            Squad[]
  nitboxAwards      NitboxAward[]
  injuries          PlayerInjury[]

  @@unique([competitionId, label])
  @@map("competition_seasons")
}

// ---------------------------------------------------------------------------
// COMPETITION GROUPS
// ---------------------------------------------------------------------------

model CompetitionGroup {
  id                  Int               @id @default(autoincrement())
  competitionSeasonId Int
  competitionSeason   CompetitionSeason @relation(fields: [competitionSeasonId], references: [id])
  name                String            @db.VarChar(50)
  stage               String            @db.VarChar(50)   // "group", "knockout"
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  matches   Match[]
  standings Standing[]

  @@unique([competitionSeasonId, name])
  @@map("competition_groups")
}

// ---------------------------------------------------------------------------
// STANDINGS
// ---------------------------------------------------------------------------

model Standing {
  id                  Int               @id @default(autoincrement())
  competitionSeasonId Int
  competitionSeason   CompetitionSeason @relation(fields: [competitionSeasonId], references: [id])
  groupId             Int?
  group               CompetitionGroup? @relation(fields: [groupId], references: [id])
  teamId              Int
  team                NationalTeam      @relation(fields: [teamId], references: [id])

  position        Int
  form            String?  @db.VarChar(20)
  status          String?  @db.VarChar(20)
  description     String?  @db.VarChar(255)

  played          Int      @default(0)
  won             Int      @default(0)
  drawn           Int      @default(0)
  lost            Int      @default(0)
  goalsFor        Int      @default(0)
  goalsAgainst    Int      @default(0)
  goalDifference  Int      @default(0)   // goalsFor - goalsAgainst (denormalized for sort)
  points          Int      @default(0)

  homePlayed       Int     @default(0)
  homeWon          Int     @default(0)
  homeDrawn        Int     @default(0)
  homeLost         Int     @default(0)
  homeGoalsFor     Int     @default(0)
  homeGoalsAgainst Int     @default(0)

  awayPlayed       Int     @default(0)
  awayWon          Int     @default(0)
  awayDrawn        Int     @default(0)
  awayLost         Int     @default(0)
  awayGoalsFor     Int     @default(0)
  awayGoalsAgainst Int     @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([competitionSeasonId, groupId, teamId])
  @@index([competitionSeasonId, position])
  @@map("standings")
}

// ---------------------------------------------------------------------------
// COACHES
// ---------------------------------------------------------------------------

model Coach {
  id              Int       @id @default(autoincrement())
  apiFootballId   Int?      @unique
  firstName       String    @db.VarChar(100)
  lastName        String    @db.VarChar(100)
  dateOfBirth     DateTime? @db.Date
  birthPlace      String?   @db.VarChar(100)
  birthCountryId  Int?
  birthCountry    Country?  @relation("CoachBirthCountry", fields: [birthCountryId], references: [id])
  nationalityId   Int?
  nationality     Country?  @relation("CoachNationality", fields: [nationalityId], references: [id])
  heightCm        Int?
  weightKg        Int?
  photoUrl        String?   @db.VarChar(500)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments  CoachAssignment[]
  matchLineups MatchLineup[]
  trophies     Trophy[]

  @@map("coaches")
}

// ---------------------------------------------------------------------------
// COACH ASSIGNMENTS
// ---------------------------------------------------------------------------

model CoachAssignment {
  id        Int          @id @default(autoincrement())
  coachId   Int
  coach     Coach        @relation(fields: [coachId], references: [id])
  teamId    Int
  team      NationalTeam @relation(fields: [teamId], references: [id])
  role      String       @db.VarChar(50)
  startDate DateTime     @db.Date
  endDate   DateTime?    @db.Date
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([coachId, teamId, startDate])
  @@map("coach_assignments")
}

// ---------------------------------------------------------------------------
// PLAYERS
// ---------------------------------------------------------------------------

model Player {
  id            Int      @id @default(autoincrement())
  apiFootballId Int      @unique
  firstName     String   @db.VarChar(100)
  lastName      String   @db.VarChar(100)
  commonName    String?  @db.VarChar(100)
  dateOfBirth   DateTime? @db.Date
  birthPlace    String?  @db.VarChar(100)
  birthCountryId Int?
  birthCountry  Country? @relation("BirthCountry", fields: [birthCountryId], references: [id])
  nationalityId Int
  nationality   Country  @relation(fields: [nationalityId], references: [id])
  position      String   @db.VarChar(10)   // "GK", "DEF", "MID", "FWD" — broad from API
  preferredFoot String?  @db.VarChar(5)
  heightCm      Int?
  weightKg      Int?
  shirtNumber   Int?
  photoUrl      String?  @db.VarChar(500)
  isActive      Boolean  @default(true)
  isInjured     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  squadPlayers      SquadPlayer[]
  matchEvents       MatchEvent[]             @relation("EventPlayer")
  assistEvents      MatchEvent[]             @relation("EventAssist")
  playerMatchStats  PlayerMatchStats[]
  playerSeasonStats PlayerSeasonStats[]
  lineupPlayers     LineupPlayer[]
  injuries          PlayerInjury[]
  nitboxAwards      NitboxAward[]
  matchPredictions  PlayerMatchPrediction[]
  trophies          Trophy[]

  @@map("players")
}

// ---------------------------------------------------------------------------
// SQUADS
// ---------------------------------------------------------------------------

model Squad {
  id                  Int                @id @default(autoincrement())
  teamId              Int
  team                NationalTeam       @relation(fields: [teamId], references: [id])
  competitionSeasonId Int?
  competitionSeason   CompetitionSeason? @relation(fields: [competitionSeasonId], references: [id])
  label               String             @db.VarChar(100)
  announcedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  squadPlayers SquadPlayer[]

  @@unique([teamId, competitionSeasonId])
  @@map("squads")
}

// ---------------------------------------------------------------------------
// SQUAD PLAYERS
// ---------------------------------------------------------------------------

model SquadPlayer {
  id          Int      @id @default(autoincrement())
  squadId     Int
  squad       Squad    @relation(fields: [squadId], references: [id])
  playerId    Int
  player      Player   @relation(fields: [playerId], references: [id])
  shirtNumber Int?
  isCaptain   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([squadId, playerId])
  @@map("squad_players")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum EnrichStatus {
  SCHEDULED
  LINEUPS_CONFIRMED
  LIVE
  FULLY_ENRICHED

  @@map("enrich_status")
}

// ---------------------------------------------------------------------------
// MATCHES
// ---------------------------------------------------------------------------

model Match {
  id                  Int               @id @default(autoincrement())
  apiFootballId       Int               @unique
  competitionSeasonId Int
  competitionSeason   CompetitionSeason @relation(fields: [competitionSeasonId], references: [id])
  groupId             Int?
  group               CompetitionGroup? @relation(fields: [groupId], references: [id])
  homeTeamId          Int
  homeTeam            NationalTeam      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId          Int
  awayTeam            NationalTeam      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venueId             Int?
  venue               Venue?            @relation(fields: [venueId], references: [id])

  kickoffAt           DateTime
  timezone            String?  @db.VarChar(50)
  periodFirstStart    Int?
  periodSecondStart   Int?

  statusShort         String   @db.VarChar(10)   // "FT", "NS", "1H", "HT", "AET", "PEN"
  statusElapsed       Int?
  statusExtra         Int?

  matchday            Int?
  roundLabel          String?  @db.VarChar(50)
  neutralVenue        Boolean  @default(false)
  attendanceActual    Int?
  refereeMain         String?  @db.VarChar(100)

  homeScore           Int?
  awayScore           Int?
  homeScoreHt         Int?
  awayScoreHt         Int?
  homeScoreEt         Int?
  awayScoreEt         Int?
  homePenScore        Int?
  awayPenScore        Int?

  enrichStatus        EnrichStatus @default(SCHEDULED)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  teamStatistics    MatchTeamStatistics[]
  events            MatchEvent[]
  lineups           MatchLineup[]
  playerStats       PlayerMatchStats[]
  nitboxAwards      NitboxAward[]
  prediction        MatchPrediction?
  playerPredictions PlayerMatchPrediction[]

  @@index([competitionSeasonId, kickoffAt])
  @@index([statusShort])
  @@index([enrichStatus])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("matches")
}

// ---------------------------------------------------------------------------
// MATCH TEAM STATISTICS
// ---------------------------------------------------------------------------

model MatchTeamStatistics {
  id              Int          @id @default(autoincrement())
  matchId         Int
  match           Match        @relation(fields: [matchId], references: [id])
  teamId          Int
  team            NationalTeam @relation(fields: [teamId], references: [id])
  // isHome removed — derivable from match.homeTeamId == teamId

  possessionPct   Float?
  shots           Int?
  shotsOnTarget   Int?
  shotsOffTarget  Int?
  shotsBlocked    Int?
  shotsInsideBox  Int?
  shotsOutsideBox Int?
  xG              Float?
  xGOt            Float?
  goalsPrevented  Float?
  passes          Int?
  passesCompleted Int?
  passAccuracyPct Float?
  corners         Int?
  fouls           Int?
  yellowCards     Int?
  redCards        Int?
  offsides        Int?
  saves           Int?
  // formation removed — use MatchLineup.formation

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([matchId, teamId])
  @@map("match_team_statistics")
}

// ---------------------------------------------------------------------------
// MATCH EVENTS
// ---------------------------------------------------------------------------

model MatchEvent {
  id             Int          @id @default(autoincrement())
  matchId        Int
  match          Match        @relation(fields: [matchId], references: [id])
  teamId         Int
  team           NationalTeam @relation(fields: [teamId], references: [id])
  playerId       Int?
  player         Player?      @relation("EventPlayer", fields: [playerId], references: [id])
  assistPlayerId Int?
  assistPlayer   Player?      @relation("EventAssist", fields: [assistPlayerId], references: [id])

  minute         Int
  extraTime      Int?
  type           String   @db.VarChar(30)    // "Goal", "Card", "subst", "Var"
  detail         String?  @db.VarChar(100)
  comments       String?  @db.VarChar(255)
  // scoreHome/Away removed — derived from sequential event log

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([matchId, minute])
  @@map("match_events")
}

// ---------------------------------------------------------------------------
// MATCH LINEUPS
// ---------------------------------------------------------------------------

model MatchLineup {
  id        Int          @id @default(autoincrement())
  matchId   Int
  match     Match        @relation(fields: [matchId], references: [id])
  teamId    Int
  team      NationalTeam @relation(fields: [teamId], references: [id])
  coachId   Int?
  coach     Coach?       @relation(fields: [coachId], references: [id])
  formation String?      @db.VarChar(10)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  lineupPlayers LineupPlayer[]

  @@unique([matchId, teamId])
  @@map("match_lineups")
}

// ---------------------------------------------------------------------------
// LINEUP PLAYERS
// ---------------------------------------------------------------------------

model LineupPlayer {
  id           Int         @id @default(autoincrement())
  lineupId     Int
  lineup       MatchLineup @relation(fields: [lineupId], references: [id])
  playerId     Int
  player       Player      @relation(fields: [playerId], references: [id])

  shirtNumber  Int?
  positionCode String?  @db.VarChar(10)
  gridPosition String?  @db.VarChar(10)
  isStarter    Boolean  @default(true)
  subbedInMin  Int?                       // derived from match events — stored for convenience
  subbedOutMin Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([lineupId, playerId])
  @@map("lineup_players")
}

// ---------------------------------------------------------------------------
// PLAYER MATCH STATISTICS
// ---------------------------------------------------------------------------

model PlayerMatchStats {
  id                Int          @id @default(autoincrement())
  matchId           Int
  match             Match        @relation(fields: [matchId], references: [id])
  playerId          Int
  player            Player       @relation(fields: [playerId], references: [id])
  teamId            Int
  team              NationalTeam @relation(fields: [teamId], references: [id])

  minutesPlayed     Int?
  rating            Float?
  captain           Boolean  @default(false)
  substitute        Boolean  @default(false)

  goals             Int      @default(0)
  goalsConceded     Int?
  assists           Int      @default(0)
  saves             Int?
  shots             Int?
  shotsOnTarget     Int?
  xG                Float?
  xA                Float?

  passes            Int?
  passesCompleted   Int?
  passAccuracyPct   Float?
  keyPasses         Int?

  tackles           Int?
  blockedShots      Int?
  interceptions     Int?
  clearances        Int?

  duelsTotal        Int?
  duelsWon          Int?

  dribbles          Int?
  dribblesCompleted Int?
  dribblesPast      Int?

  foulsCommitted    Int?
  foulsSuffered     Int?
  yellowCards       Int      @default(0)
  redCards          Int      @default(0)
  offsides          Int?

  penaltyWon        Int?
  penaltyCommitted  Int?
  penaltyScored     Int?
  penaltyMissed     Int?
  penaltySaved      Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([playerId])
  @@map("player_match_stats")
}

// ---------------------------------------------------------------------------
// PLAYER SEASON STATISTICS
// ---------------------------------------------------------------------------

model PlayerSeasonStats {
  id                  Int               @id @default(autoincrement())
  playerId            Int
  player              Player            @relation(fields: [playerId], references: [id])
  competitionSeasonId Int
  competitionSeason   CompetitionSeason @relation(fields: [competitionSeasonId], references: [id])
  teamId              Int
  team                NationalTeam      @relation(fields: [teamId], references: [id])

  appearances         Int      @default(0)
  starts              Int      @default(0)   // games.lineups from API
  minutesPlayed       Int      @default(0)
  goals               Int      @default(0)
  assists             Int      @default(0)
  xG                  Float?
  xA                  Float?
  shots               Int?
  shotsOnTarget       Int?
  passes              Int?
  passesCompleted     Int?
  keyPasses           Int?
  dribbles            Int?
  dribblesCompleted   Int?
  tackles             Int?
  interceptions       Int?
  clearances          Int?
  foulsCommitted      Int?
  foulsSuffered       Int?
  saves               Int?
  yellowCards         Int      @default(0)
  redCards            Int      @default(0)
  penaltyScored       Int?
  penaltyMissed       Int?
  averageRating       Float?   // computed from PlayerMatchStats

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([playerId, competitionSeasonId, teamId])
  @@index([competitionSeasonId, goals])
  @@map("player_season_stats")
}

// ---------------------------------------------------------------------------
// TEAM SEASON STATISTICS
// ---------------------------------------------------------------------------

model TeamSeasonStats {
  id                  Int               @id @default(autoincrement())
  teamId              Int
  team                NationalTeam      @relation(fields: [teamId], references: [id])
  competitionSeasonId Int
  competitionSeason   CompetitionSeason @relation(fields: [competitionSeasonId], references: [id])

  form                String?  @db.VarChar(30)

  matchesPlayed       Int      @default(0)
  wins                Int      @default(0)
  draws               Int      @default(0)
  losses              Int      @default(0)

  homeMatchesPlayed   Int      @default(0)
  homeWins            Int      @default(0)
  homeDraws           Int      @default(0)
  homeLosses          Int      @default(0)

  awayMatchesPlayed   Int      @default(0)
  awayWins            Int      @default(0)
  awayDraws           Int      @default(0)
  awayLosses          Int      @default(0)

  goalsFor            Int      @default(0)
  goalsAgainst        Int      @default(0)
  goalsForHome        Int      @default(0)
  goalsForAway        Int      @default(0)
  goalsAgainstHome    Int      @default(0)
  goalsAgainstAway    Int      @default(0)
  goalsForAvg         Float?   // from API: goals.for.average.total
  goalsAgainstAvg     Float?   // from API: goals.against.average.total

  cleanSheets         Int      @default(0)
  cleanSheetsHome     Int      @default(0)
  cleanSheetsAway     Int      @default(0)
  failedToScore       Int      @default(0)

  biggestWinHome      String?  @db.VarChar(10)
  biggestWinAway      String?  @db.VarChar(10)
  biggestLossHome     String?  @db.VarChar(10)
  biggestLossAway     String?  @db.VarChar(10)

  winStreak           Int?
  drawStreak          Int?
  lossStreak          Int?

  penaltiesScored     Int?
  penaltiesMissed     Int?
  penaltiesTotal      Int?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([teamId, competitionSeasonId])
  @@map("team_season_stats")
}

// ---------------------------------------------------------------------------
// TROPHIES
// ---------------------------------------------------------------------------
// Supports team trophies (won World Cup), player trophies (Golden Boot),
// and coach trophies. Exactly one of teamId/playerId/coachId should be set.
// type distinguishes the award: "champion", "runner_up", "golden_boot", etc.

model Trophy {
  id                  Int               @id @default(autoincrement())
  competitionSeasonId Int
  competitionSeason   CompetitionSeason @relation(fields: [competitionSeasonId], references: [id])
  type                String            @db.VarChar(50)  // "champion", "runner_up", "golden_boot", "golden_ball", "golden_glove"
  placement           Int?                               // 1 = winner, 2 = runner-up (for team trophies)

  teamId    Int?
  team      NationalTeam? @relation(fields: [teamId], references: [id])
  playerId  Int?
  player    Player?       @relation(fields: [playerId], references: [id])
  coachId   Int?
  coach     Coach?        @relation(fields: [coachId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, type, competitionSeasonId])
  @@unique([playerId, type, competitionSeasonId])
  @@unique([coachId, type, competitionSeasonId])
  @@map("trophies")
}

// ---------------------------------------------------------------------------
// PLAYER INJURIES
// ---------------------------------------------------------------------------

model PlayerInjury {
  id                  Int                @id @default(autoincrement())
  playerId            Int
  player              Player             @relation(fields: [playerId], references: [id])
  competitionSeasonId Int?
  competitionSeason   CompetitionSeason? @relation(fields: [competitionSeasonId], references: [id])
  injuryType          String             @db.VarChar(100)
  bodyPart            String?            @db.VarChar(50)
  startDate           DateTime           @db.Date
  endDate             DateTime?          @db.Date
  matchesMissed       Int?
  severity            String?            @db.VarChar(20)
  notes               String?            @db.Text
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("player_injuries")
}

// ---------------------------------------------------------------------------
// NITBOX AWARDS
// ---------------------------------------------------------------------------

enum NitboxAwardType {
  PLAYER_OF_MATCH
  PLAYER_OF_SEASON
  PLAYER_OF_CUP
  BEST_DEFENSIVE

  @@map("nitbox_award_type")
}

model NitboxAward {
  id                  Int              @id @default(autoincrement())
  type                NitboxAwardType
  playerId            Int
  player              Player           @relation(fields: [playerId], references: [id])
  matchId             Int?
  match               Match?           @relation(fields: [matchId], references: [id])
  competitionSeasonId Int?
  competitionSeason   CompetitionSeason? @relation(fields: [competitionSeasonId], references: [id])
  seasonYear          Int
  score               Float
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([type, matchId])
  @@unique([type, competitionSeasonId])
  @@map("nitbox_awards")
}

// ---------------------------------------------------------------------------
// ML PREDICTIONS
// ---------------------------------------------------------------------------

model MatchPrediction {
  id              Int      @id @default(autoincrement())
  matchId         Int      @unique
  match           Match    @relation(fields: [matchId], references: [id])
  modelVersion    String   @db.VarChar(50)
  homeWinProb     Float
  drawProb        Float
  awayWinProb     Float
  predictedResult String   @db.VarChar(10)   // "HOME" | "DRAW" | "AWAY"
  confidence      Float
  modelScores     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("match_predictions")
}

model PlayerMatchPrediction {
  id               Int      @id @default(autoincrement())
  matchId          Int
  match            Match    @relation(fields: [matchId], references: [id])
  playerId         Int
  player           Player   @relation(fields: [playerId], references: [id])
  predictedRating  Float?
  predictedGoals   Float?
  predictedAssists Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([matchId, playerId])
  @@map("player_match_predictions")
}
